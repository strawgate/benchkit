{
  "name": "benchkit",
  "private": true,
  "workspaces": [
    "packages/*",
    "actions/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/format && npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . && npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.4",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0"
  }
}
